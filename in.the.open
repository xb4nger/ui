getgenv().kill_gun = function(targetPlayer)
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("Head") then return end
    
    getgenv().character = getgenv().LocalPlayer.Character
    if not getgenv().character then return end
    
    getgenv().tool = getgenv().character:FindFirstChildOfClass("Tool")
    if not getgenv().tool then return end
    
    getgenv().hitpart = targetPlayer.Character.Head
    getgenv().hitpos = getgenv().hitpart.Position
    getgenv().damage = math.huge
    
    getgenv().setting = getgenv().tool:FindFirstChild("Setting")
    if getgenv().setting then
        pcall(function()
            require(getgenv().setting).Range = 10000
        end)
    end
    
    getgenv().ReplicatedStorage.VisualizeMuzzle:FireServer(
        getgenv().tool.Handle,
        true,
        {false, 7, Color3.new(1, 1, 0), 15, true, 0.02},
        getgenv().tool.GunScript_Local.MuzzleEffect
    )
    
    getgenv().ReplicatedStorage.VisualizeBullet:FireServer(
        getgenv().tool,
        getgenv().tool.Handle,
        Vector3.new(-0.177, 0.088, 0.980),
        getgenv().tool.Handle.GunFirePoint,
        {true, {112139677907600, 92977228204408, 112139677907600, 92977228204408}, 1, 1, 10, getgenv().tool.GunScript_Local.HitEffect, true},
        {true, {0,0,0,0,0,0}, 1,1,1, getgenv().tool.GunScript_Local.BloodEffect},
        {true, 0.2, {3696144972}, true, 7, 1},
        {false, 8, true, {163064102}, 1, 1.5, 1, false, getgenv().tool.GunScript_Local.ExplosionEffect},
        {false, Vector3.new(0.1,0,0), Vector3.new(-0.1,0,0), getgenv().tool.GunScript_Local.TracerEffect, nil, getgenv().tool.GunScript_Local.ParticleEffect, 300, 526, 0, Vector3.zero, Vector3.new(0.4,0.4,0.4), Color3.new(0.639,0.635,0.611), 1, Enum.Material.Neon, Enum.PartType.Cylinder, false, 6696543809, 0, Vector3.new(0.007,0.007,0.007)},
        {true, {269514869,269514887,269514807,269514817}, 0.5, 1, 1.5, 100},
        {false, 3, Color3.new(1,0.647,0.6), 6, true}
    )
    
    getgenv().ReplicatedStorage.InflictTarget:FireServer(
        getgenv().tool,
        getgenv().LocalPlayer,
        targetPlayer.Character:FindFirstChildOfClass("Humanoid"),
        getgenv().hitpart,
        getgenv().damage,
        {0, 0, false, false, getgenv().tool.GunScript_Server.IgniteScript, getgenv().tool.GunScript_Server.IcifyScript, 100, 100},
        {false, 5, 3},
        getgenv().hitpart,
        {false, {1930359546}, 1, 1.5, 1},
        getgenv().hitpos,
        Vector3.new(0.074, -0.099, -0.992),
        true
    )
end

