getgenv().StarterScreen = "Default"

local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

local protect_gui = protect_gui or (syn and syn.protect_gui) or function(gui)
	if gethui then gui.Parent = gethui() else gui.Parent = CoreGui end
end

local function RandomString(len)
	local s, c = "", "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
	for i = 1, len or 12 do
		local r = math.random(1, #c)
		s = s .. c:sub(r, r)
	end
	return s
end

local function Tween(o, t, p)
	local tw = TweenService:Create(o, TweenInfo.new(t or 1, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), p)
	tw:Play()
	return tw
end

local function ExampleHubLoader(cfg)
	cfg = cfg or {}
	cfg.Name = cfg.Name or "FrostWare"
	cfg.Style = cfg.Style or "Default"
	cfg.Scale = cfg.Scale or 3
	cfg.Font = cfg.Font or Enum.Font.DenkOne -- use Denk One

	local gui = Instance.new("ScreenGui")
	gui.Name = RandomString()
	gui.IgnoreGuiInset = true
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
	protect_gui(gui)

	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundTransparency = 1
	bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bg.Parent = gui

	local grad = Instance.new("UIGradient")
	grad.Rotation = 0

	if cfg.Style == "Halloween" then
		grad.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 0, 0)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(150, 60, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 0, 0))
		}
	elseif cfg.Style == "Christmas" then
		grad.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 160, 80)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 60, 60)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 160, 80))
		}
	else
		grad.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(235, 245, 255)),
			ColorSequenceKeypoint.new(0.4, Color3.fromRGB(170, 220, 255)),
			ColorSequenceKeypoint.new(0.7, Color3.fromRGB(120, 190, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(235, 245, 255))
		}
	end
	grad.Parent = bg

	local vignette = Instance.new("ImageLabel")
	vignette.Size = UDim2.new(1.1, 0, 1.1, 0)
	vignette.AnchorPoint = Vector2.new(0.5, 0.5)
	vignette.Position = UDim2.new(0.5, 0, 0.5, 0)
	vignette.BackgroundTransparency = 1
	vignette.Image = "rbxassetid://7143647374"
	vignette.ImageColor3 = Color3.fromRGB(180, 220, 255)
	vignette.ImageTransparency = 1
	vignette.ZIndex = 2
	vignette.Parent = bg

	local frame = Instance.new("Frame")
	frame.AnchorPoint = Vector2.new(0.5, 0.5)
	frame.Position = UDim2.new(0.5, 0, 0.5, 0)
	frame.BackgroundTransparency = 1
	frame.Size = UDim2.new(0, 0, 0, 0)
	frame.Parent = gui

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Padding = UDim.new(0, 6 * cfg.Scale)
	layout.Parent = frame

	Tween(blur, 2, { Size = 75 })
	Tween(bg, 1.5, { BackgroundTransparency = 0.05 })
	Tween(vignette, 2, { ImageTransparency = 0.2 })

	task.spawn(function()
		while gui.Parent do
			grad.Rotation = grad.Rotation + 1
			task.wait(0.05)
		end
	end)

	task.wait(1.2)

	local colorThemes = {
		Default = {
			Color3.fromRGB(220, 240, 255),
			Color3.fromRGB(150, 210, 255),
			Color3.fromRGB(90, 170, 255)
		}
	}

	local theme = colorThemes[cfg.Style] or colorThemes.Default
	local letters = {}

	for _, ch in ipairs(cfg.Name:split("")) do
		local holder = Instance.new("Frame")
		holder.BackgroundTransparency = 1
		holder.Size = UDim2.new(0, 32 * cfg.Scale, 0, 80 * cfg.Scale)
		holder.Parent = frame

		local lbl = Instance.new("TextLabel")
		lbl.AnchorPoint = Vector2.new(0.5, 0.5)
		lbl.Position = UDim2.new(0.5, 0, 0.5, 0)
		lbl.BackgroundTransparency = 1
		lbl.Font = cfg.Font
		lbl.Text = ch
		lbl.TextSize = 55
		lbl.TextTransparency = 1
		lbl.TextColor3 = Color3.new(1, 1, 1)
		lbl.Rotation = 0 -- STRAIGHT
		lbl.ZIndex = 5
		lbl.Parent = holder

		local gradTxt = Instance.new("UIGradient")
		gradTxt.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, theme[1]),
			ColorSequenceKeypoint.new(0.5, theme[2]),
			ColorSequenceKeypoint.new(1, theme[3])
		}
		gradTxt.Rotation = -45
		gradTxt.Parent = lbl

		local scale = Instance.new("UIScale")
		scale.Scale = cfg.Scale
		scale.Parent = lbl

		table.insert(letters, lbl)
	end

	for i, lbl in ipairs(letters) do
		task.delay(i * 0.15, function()
			Tween(lbl, 0.8, { TextTransparency = 0, Rotation = 0 })
		end)
	end

	task.wait(#letters * 0.15 + 2.5)

	for i, lbl in ipairs(letters) do
		task.delay(i * 0.1, function()
			Tween(lbl, 1, {
				TextTransparency = 1,
				Position = lbl.Position + UDim2.new(0, 0, 0.5, 0)
			})
		end)
	end

	task.wait(1.5)
	Tween(vignette, 2, { ImageTransparency = 1 })
	Tween(blur, 2, { Size = 0 })
	Tween(bg, 2, { BackgroundTransparency = 1 })
	task.wait(1.2)
end

