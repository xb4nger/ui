ExtraBox:AddToggle('BypassLockedCars', {
    Text = 'Bypass Locked Cars',
    Default = false,
    Callback = function(state)
        ModFlags.BypassLockedCars = state
        if state then
            SeatConnection = ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt, playerWhoTriggered)
                if playerWhoTriggered ~= LocalPlayer or not ModFlags.BypassLockedCars then return end
                local seat = findVehicleSeat(prompt.Parent)
                if not seat then return end
                local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local humanoid = character:WaitForChild("Humanoid")
                if seat:IsA("VehicleSeat") then
                    seat:Sit(humanoid)
                else
                    humanoid.Sit = false
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait()
                    seat:Sit(humanoid)
                end
            end)
        else
            if SeatConnection then
                SeatConnection:Disconnect()
                SeatConnection = nil
            end
        end
    end,
})





