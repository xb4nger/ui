local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local InfiniteMags = false
local OldWeaponValues = {}
local SetInfiniteAmmo = {}

local function GetAllTools(includeCharacter)
    local tools = {}

    for _,v in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") then
            table.insert(tools, v)
        end
    end

    if includeCharacter and LocalPlayer.Character then
        for _,v in ipairs(LocalPlayer.Character:GetChildren()) do
            if v:IsA("Tool") then
                table.insert(tools, v)
            end
        end
    end

    return tools
end

local function SaveOldValues(tool)
    local moduleScript = tool:FindFirstChildOfClass("ModuleScript")
    if not moduleScript or moduleScript.Name ~= "Setting" then return end

    local Module = require(moduleScript)

    if type(Module) == "table" and not OldWeaponValues[tool] then
        OldWeaponValues[tool] = {}
        for i,v in pairs(Module) do
            OldWeaponValues[tool][i] = v
        end
    end
end

local function ApplyInfinite(tool)
    if not tool:IsA("Tool") then return end

    local gunScript = tool:FindFirstChild("GunScript_Local")
    if not gunScript then return end

    local env = getsenv(gunScript)
    if not env then return end

    local moduleScript = tool:FindFirstChildOfClass("ModuleScript")
    local Module

    if moduleScript and moduleScript.Name == "Setting" then
        Module = require(moduleScript)
    end

    if InfiniteMags then
        if env.Reload then
            debug.setupvalue(env.Reload, 1, 1e1)
            SetInfiniteAmmo[tool] = true
        end

        if Module then
            Module.LimitedAmmoEnabled = false
        end
    else
        if SetInfiniteAmmo[tool] and OldWeaponValues[tool] then
            debug.setupvalue(env.Reload, 1, OldWeaponValues[tool].AmmoPerMag)
            SetInfiniteAmmo[tool] = nil
        end

        if Module and OldWeaponValues[tool] then
            Module.LimitedAmmoEnabled = OldWeaponValues[tool].LimitedAmmoEnabled
        end
    end
end

local function ApplyToAll()
    for _,tool in ipairs(GetAllTools(true)) do
        SaveOldValues(tool)
        ApplyInfinite(tool)
    end
end


DupeGunBox:AddToggle("InfiniteMags", {
    Text = "Infinite Clips",
    Default = false,
    Callback = function(state)
        InfiniteMags = state
        ApplyToAll()
    end
})


LocalPlayer.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            task.wait()
