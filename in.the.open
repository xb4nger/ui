local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer
local MaxDistance = 10000

local MasterGui = CoreGui:FindFirstChild("UnifiedESP") or Instance.new("ScreenGui")
MasterGui.Name = "UnifiedESP"
MasterGui.ResetOnSpawn = false
MasterGui.Parent = CoreGui

local Drawn = {}
local Connections = {}

local TextColor = Color3.fromRGB(255, 255, 255)

local ESPColors = {
    BoxCorner = Color3.fromRGB(255, 255, 255),
    BoxFillSolid = Color3.fromRGB(0, 0, 0),
    ChamsFill = Color3.fromRGB(119, 120, 255),
    ChamsOutline = Color3.fromRGB(0, 0, 0)
}

local GradientColors = {
    FullBoxFill = {Color1 = Color3.fromRGB(119, 120, 255), Color2 = Color3.fromRGB(0, 0, 0)},
    FullBoxOutline = {Color1 = Color3.fromRGB(119, 120, 255), Color2 = Color3.fromRGB(0, 0, 0)},
    Health = {Color1 = Color3.fromRGB(255, 0, 0), Color2 = Color3.fromRGB(0, 255, 0)}
}

local Toggles = {
    Name = false,
    Weapon = false,
    Distance = false,
    Health = false,
    BoxCorner = false,
    BoxFull = false,
    Chams = false
}

local Settings = {
    BoxCornerThickness = 1.5,
    BoxFillTransparency = 0.75,
    HealthWidth = 2.5,
    ChamsFillTransparency = 0.80,
    ChamsOutlineTransparency = 0.80,
    FullBoxRotationSpeed = 180
}

local BoxObjects = {}
local RotationAngles = {}
local RotationLastTime = {}

local function clearPlayer(name)
    if Drawn[name] then
        for _, v in ipairs(Drawn[name]) do
            if typeof(v) == "Instance" then pcall(function() v:Destroy() end)
            elseif typeof(v) == "RBXScriptConnection" then pcall(function() v:Disconnect() end) end
        end
        Drawn[name] = nil
        BoxObjects[name] = nil
        RotationAngles[name] = nil
        RotationLastTime[name] = nil
    end
end

local function Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    inst.Parent = MasterGui
    return inst
end

local function CreateText()
    return Create("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        TextSize = 14,
        TextColor3 = TextColor,
        TextStrokeTransparency = 0.7,
        TextStrokeColor3 = Color3.new(0,0,0),
        Size = UDim2.new(0, 260, 0, 20),
        AnchorPoint = Vector2.new(0.5, 0),
        ZIndex = 5,
        Visible = false
    })
end

local function makeCorners()
    local corners = {}
    for i = 1, 8 do
        local f = Create("Frame", {
            BackgroundColor3 = ESPColors.BoxCorner,
            BorderSizePixel = 0,
            ZIndex = 4,
            Visible = false
        })
        table.insert(corners, f)
    end
    return corners
end

local function createHealthParts()
    local outline = Create("Frame", {BackgroundColor3 = Color3.new(0,0,0), BorderSizePixel = 0, ZIndex = 1, Visible = false})
    local back = Create("Frame", {BackgroundColor3 = Color3.fromRGB(35,35,35), BorderSizePixel = 0, ZIndex = 2, Visible = false})
    local bar = Create("Frame", {BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0, ZIndex = 3, Visible = false})

    local healthGrad = Instance.new("UIGradient")
    healthGrad.Rotation = -90
    healthGrad.Parent = bar

    return outline, back, bar, healthGrad
end

local function applyChams(char, enabled)
    if not char then return end
    local old = char:FindFirstChild("ThermalHighlight")
    if old then old:Destroy() end
    if not enabled then return end
    local h = Instance.new("Highlight")
    h.Name = "ThermalHighlight"
    h.Adornee = char
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.FillColor = ESPColors.ChamsFill
    h.FillTransparency = Settings.ChamsFillTransparency
    h.OutlineTransparency = Settings.ChamsOutlineTransparency
    h.OutlineColor = ESPColors.ChamsOutline
    h.Parent = char
end

local function PlayerESP(plr)
    if plr == LocalPlayer then return end
    clearPlayer(plr.Name)
    Drawn[plr.Name] = {}
    RotationAngles[plr.Name] = 0
    RotationLastTime[plr.Name] = tick()

    local nameTxt = CreateText()
    local weaponTxt = CreateText()
    local distTxt = CreateText()
    local corners = makeCorners()
    local hOutline, hBack, hBar, healthGradient = createHealthParts()

    local box = Create("Frame", {BorderSizePixel = 0, ZIndex = 2, Visible = false})
    local boxGrad = Instance.new("UIGradient")
    boxGrad.Rotation = -45
    boxGrad.Parent = box

    local boxStroke = Instance.new("UIStroke")
    boxStroke.Transparency = 0
    boxStroke.Thickness = 1
    boxStroke.Parent = box

    local boxStrokeGrad = Instance.new("UIGradient")
    boxStrokeGrad.Rotation = -45
    boxStrokeGrad.Parent = boxStroke

    for _, obj in {nameTxt, weaponTxt, distTxt, hOutline, hBack, hBar, box} do
        table.insert(Drawn[plr.Name], obj)
    end
    for _, c in ipairs(corners) do table.insert(Drawn[plr.Name], c) end

    BoxObjects[plr.Name] = {box = box, grad = boxGrad, stroke = boxStroke, strokeGrad = boxStrokeGrad}

    local function update()
        local char = plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not (char and root and hum and hum.Health > 0) then
            for _, v in ipairs(Drawn[plr.Name]) do
                if v and typeof(v) == "Instance" and v:IsA("GuiObject") then
                    v.Visible = false
                end
            end
            return
        end

        local screenPos, onScreen = Camera:WorldToScreenPoint(root.Position)
        local dist = (Camera.CFrame.Position - root.Position).Magnitude
        if not onScreen or screenPos.Z > MaxDistance or screenPos.Z < 1 then
            for _, v in ipairs(Drawn[plr.Name]) do
                if v and typeof(v) == "Instance" and v:IsA("GuiObject") then
                    v.Visible = false
                end
            end
            return
        end

        local scale = math.clamp(11.5 / (screenPos.Z * math.tan(math.rad(Camera.FieldOfView * 0.5))) * 100, 8, 600)
        local w = 1.9 * scale
        local h = 2.9 * scale
        local centerX = screenPos.X
        local topY = screenPos.Y - h / 2
        local bottomY = screenPos.Y + h / 2
        local textScale = math.clamp(1 / (dist * 0.003 + 0.5), 0.7, 1.4)

        if Toggles.Name then
            nameTxt.Text = plr.Name
            nameTxt.Position = UDim2.new(0, centerX, 0, topY - 22 * textScale)
            nameTxt.TextSize = math.floor(15 * textScale)
            nameTxt.Visible = true
        else
            nameTxt.Visible = false
        end

        local nextY = bottomY + 6 * textScale
        if Toggles.Weapon then
            local tool = char:FindFirstChildOfClass("Tool")
            weaponTxt.Text = tool and tool.Name or "None"
            weaponTxt.Position = UDim2.new(0, centerX, 0, nextY)
            weaponTxt.TextSize = math.floor(14 * textScale)
            weaponTxt.Visible = true
            nextY = nextY + 18 * textScale
        else
            weaponTxt.Visible = false
        end

        if Toggles.Distance then
            distTxt.Text = math.floor(dist) .. " studs"
            distTxt.Position = UDim2.new(0, centerX, 0, nextY)
            distTxt.TextSize = math.floor(14 * textScale)
            distTxt.Visible = true
        else
            distTxt.Visible = false
        end

        if Toggles.BoxFull then
            local obj = BoxObjects[plr.Name]
            obj.box.Position = UDim2.new(0, centerX - w/2, 0, topY)
            obj.box.Size = UDim2.new(0, w, 0, h)
            obj.box.Visible = true

            obj.box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            obj.box.BackgroundTransparency = Settings.BoxFillTransparency
            obj.box.BorderSizePixel = 1

            obj.grad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, GradientColors.FullBoxFill.Color1),
                ColorSequenceKeypoint.new(1, GradientColors.FullBoxFill.Color2)
            }
            obj.strokeGrad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, GradientColors.FullBoxOutline.Color1),
                ColorSequenceKeypoint.new(1, GradientColors.FullBoxOutline.Color2)
            }

            local now = tick()
            local last = RotationLastTime[plr.Name] or now
            local delta = now - last
            RotationAngles[plr.Name] = (RotationAngles[plr.Name] + delta * Settings.FullBoxRotationSpeed) % 360
            RotationLastTime[plr.Name] = now

            obj.grad.Rotation = RotationAngles[plr.Name]
            obj.strokeGrad.Rotation = RotationAngles[plr.Name]
            obj.grad.Enabled = true
            obj.strokeGrad.Enabled = true
        else
            if BoxObjects[plr.Name] then
                BoxObjects[plr.Name].box.Visible = false
            end
        end

        if Toggles.BoxCorner then
            local arm = math.max(4, w * 0.22)
            local thick = Settings.BoxCornerThickness
            local positions = {
                {centerX - w/2, topY, arm, thick},
                {centerX - w/2, topY, thick, arm},
                {centerX + w/2 - arm, topY, arm, thick},
                {centerX + w/2 - thick, topY, thick, arm},
                {centerX - w/2, bottomY - thick, arm, thick},
                {centerX - w/2, bottomY - arm, thick, arm},
                {centerX + w/2 - arm, bottomY - thick, arm, thick},
                {centerX + w/2 - thick, bottomY - arm, thick, arm}
            }

            for i = 1, 8 do
                local x,y,sx,sy = unpack(positions[i])
                local f = corners[i]
                f.Position = UDim2.new(0,x,0,y)
                f.Size = UDim2.new(0,sx,0,sy)
                f.Visible = true
            end
        else
            for _, f in ipairs(corners) do f.Visible = false end
        end

        if Toggles.Health then
            local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            local fillH = h * hp
            local barX = centerX - w / 2 - 8
            local barY = topY

            hOutline.Position = UDim2.new(0, barX - 1, 0, barY - 1)
            hOutline.Size = UDim2.new(0, Settings.HealthWidth + 2, 0, h + 2)
            hBack.Position = UDim2.new(0, barX, 0, barY)
            hBack.Size = UDim2.new(0, Settings.HealthWidth, 0, h)
            hBar.Position = UDim2.new(0, barX, 0, barY + h - fillH)
            hBar.Size = UDim2.new(0, Settings.HealthWidth, 0, fillH)

            healthGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, GradientColors.Health.Color1),
                ColorSequenceKeypoint.new(1, GradientColors.Health.Color2)
            }
            healthGradient.Enabled = true

            hBar.Visible = true
            hOutline.Visible = true
            hBack.Visible = true
        else
            hOutline.Visible = false
            hBack.Visible = false
            hBar.Visible = false
            healthGradient.Enabled = false
        end
    end

    local renderConn = RunService.RenderStepped:Connect(update)
    table.insert(Drawn[plr.Name], renderConn)
    table.insert(Connections, renderConn)

    local charAddedConn = plr.CharacterAdded:Connect(function(c)
        task.wait(0.1)
        if Toggles.Chams then applyChams(c, true) end
        update()
    end)
    table.insert(Drawn[plr.Name], charAddedConn)
    table.insert(Connections, charAddedConn)

    if plr.Character and Toggles.Chams then applyChams(plr.Character, true) end
end

Players.PlayerRemoving:Connect(clearPlayer)
for _, p in ipairs(Players:GetPlayers()) do task.spawn(PlayerESP, p) end
Players.PlayerAdded:Connect(function(p) task.spawn(PlayerESP, p) end)

if ESPGroupbox then
    ESPGroupbox:AddToggle("NameESP", {Text = "Name", Default = false, Callback = function(v) Toggles.Name = v end})

    ESPGroupbox:AddToggle("WeaponESP", {Text = "Item", Default = false, Callback = function(v) Toggles.Weapon = v end})

    ESPGroupbox:AddToggle("DistanceESP", {Text = "Distance", Default = false, Callback = function(v) Toggles.Distance = v end})

    ESPGroupbox:AddToggle("HealthESP", {Text = "Health Bar", Default = false, Callback = function(v) Toggles.Health = v end})
        :AddColorPicker("HealthLow", {Default = GradientColors.Health.Color1, Callback = function(c) GradientColors.Health.Color1 = c end})
        :AddColorPicker("HealthHigh", {Default = GradientColors.Health.Color2, Callback = function(c) GradientColors.Health.Color2 = c end})

    ESPGroupbox:AddToggle("BoxCornerESP", {Text = "Corner Box", Default = false, Callback = function(v) Toggles.BoxCorner = v end})
        :AddColorPicker("CornerColor", {Default = ESPColors.BoxCorner, Callback = function(c) ESPColors.BoxCorner = c end})

    ESPGroupbox:AddToggle("BoxFullESP", {Text = "Fill Box", Default = false, Callback = function(v) Toggles.BoxFull = v end})
        :AddColorPicker("FillGradient1", {Default = GradientColors.FullBoxFill.Color1, Callback = function(c) GradientColors.FullBoxFill.Color1 = c end})
        :AddColorPicker("FillGradient2", {Default = GradientColors.FullBoxFill.Color2, Callback = function(c) GradientColors.FullBoxFill.Color2 = c end})
        :AddColorPicker("OutlineGradient1", {Default = GradientColors.FullBoxOutline.Color1, Callback = function(c) GradientColors.FullBoxOutline.Color1 = c end})
        :AddColorPicker("OutlineGradient2", {Default = GradientColors.FullBoxOutline.Color2, Callback = function(c) GradientColors.FullBoxOutline.Color2 = c end})

    ESPGroupbox:AddToggle("ChamsESP", {Text = "Chams", Default = false, Callback = function(v)
        Toggles.Chams = v
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then applyChams(p.Character, v) end
        end
    end})
        :AddColorPicker("ChamsFill", {Default = ESPColors.ChamsFill, Callback = function(c) ESPColors.ChamsFill = c end})
        :AddColorPicker("ChamsOutline", {Default = ESPColors.ChamsOutline, Callback = function(c) ESPColors.ChamsOutline = c end})
end


getgenv().Players = game:GetService("Players")
getgenv().RunService = game:GetService("RunService")
getgenv().LocalPlayer = getgenv().Players.LocalPlayer

getgenv().PlayerChamsEnabled = false
getgenv().PlayerChamsRainbow = false
getgenv().PlayerChamsColor = Color3.fromRGB(0,255,255)
getgenv().PlayerChamsTransparency = 0.25
getgenv().PlayerMaterial = "ForceField"
getgenv().PlayerAnim = "Static"

getgenv().GunChamsEnabled = false

getgenv().PlayerOriginal = {}
getgenv().GunOriginal = {}
getgenv().CurrentTool = nil

getgenv().PatternSpeed = 3

local function PatternValue(part, mode)
    local t = tick() * getgenv().PatternSpeed
    if mode == "Static" then
        return 1
    elseif mode == "Wave" then
        return (math.sin(t + part.Position.X * 0.2 + part.Position.Y * 0.2) + 1) * 0.5
    elseif mode == "Pulse" then
        return (math.sin(t * 2) + 1) * 0.5
    elseif mode == "Noise" then
        return (math.noise(part.Position.X * 0.1, part.Position.Y * 0.1, t * 0.5) + 1) * 0.5
    elseif mode == "Lightning" then
        return math.abs(math.sin(t * 12 + part.Position.X)) * 0.8 + 0.2
    elseif mode == "Scanline" then
        return math.clamp(math.sin(t + part.Position.Y * 0.5) * 1.2, 0, 1)
    elseif mode == "Grid" then
        local gx = math.abs(math.sin(part.Position.X * 0.3 + t * 1.5))
        local gy = math.abs(math.sin(part.Position.Y * 0.3 + t * 1.5))
        return (gx + gy) * 0.5
    end
    return 1
end

local function ShouldCham(part)
    if not part:IsA("BasePart") then return false end
    if part.Name == "HumanoidRootPart" then return false end
    if part.Parent:IsA("Accessory") then return false end
    return true
end

local function ApplyChams(char, orig, material, anim, color, trans)
    for _, part in ipairs(char:GetDescendants()) do
        if ShouldCham(part) then
            if not orig[part] then
                orig[part] = {Material = part.Material, Color = part.Color, Transparency = part.Transparency}
            end
            local p = PatternValue(part, anim)
            pcall(function()
                part.Material = Enum.Material[material]
                part.Color = Color3.new(color.R * p, color.G * p, color.B * p)
                part.Transparency = trans
            end)
        end
    end
end

local function ResetChams(orig)
    for part, data in pairs(orig) do
        if part and part.Parent then
            pcall(function()
                part.Material = data.Material
                part.Color = data.Color
                part.Transparency = data.Transparency
            end)
        end
    end
    orig = {}
end

local function ApplyPlayer()
    if not getgenv().PlayerChamsEnabled or not getgenv().LocalPlayer.Character then return end
    local c = getgenv().PlayerChamsRainbow and Color3.fromHSV((tick() % 5) / 5, 1, 1) or getgenv().PlayerChamsColor
    ApplyChams(getgenv().LocalPlayer.Character, getgenv().PlayerOriginal, getgenv().PlayerMaterial, getgenv().PlayerAnim, c, getgenv().PlayerChamsTransparency)
end

local function ApplyGun()
    if not getgenv().GunChamsEnabled or not getgenv().PlayerChamsEnabled or not getgenv().CurrentTool then return end
    local c = getgenv().PlayerChamsRainbow and Color3.fromHSV((tick() % 5) / 5, 1, 1) or getgenv().PlayerChamsColor
    ApplyChams(getgenv().CurrentTool, getgenv().GunOriginal, getgenv().PlayerMaterial, getgenv().PlayerAnim, c, getgenv().PlayerChamsTransparency)
end

local function HookTool(tool)
    if not tool:IsA("Tool") then return end
    tool.Equipped:Connect(function()
        getgenv().CurrentTool = tool
        ApplyGun()
    end)
    tool.Unequipped:Connect(function()
        if getgenv().CurrentTool == tool then
            ResetChams(getgenv().GunOriginal)
            getgenv().CurrentTool = nil
        end
    end)
end

local function HookCharacter(char)
    char.ChildAdded:Connect(HookTool)
    for _, c in ipairs(char:GetChildren()) do HookTool(c) end
    task.wait(0.3)
    ApplyPlayer()
end

if getgenv().LocalPlayer.Character then HookCharacter(getgenv().LocalPlayer.Character) end
getgenv().LocalPlayer.CharacterAdded:Connect(HookCharacter)

Tab1:AddToggle("PlayerChams", {
    Text = "Enable Player Chams",
    Default = getgenv().PlayerChamsEnabled,
    Callback = function(v)
        getgenv().PlayerChamsEnabled = v
        if v then ApplyPlayer() else ResetChams(getgenv().PlayerOriginal) end
    end
}):AddColorPicker("PlayerChamsColorPicker", {
    Default = getgenv().PlayerChamsColor,
    Callback = function(v)
        getgenv().PlayerChamsColor = v
    end
})

Tab1:AddToggle("PlayerRainbow", {
    Text = "Rainbow",
    Default = getgenv().PlayerChamsRainbow,
    Callback = function(v)
        getgenv().PlayerChamsRainbow = v
    end
})

Tab1:AddDropdown("PlayerMaterialDropdown", {
    Values = {"ForceField", "Neon"},
    Default = getgenv().PlayerMaterial,
    Callback = function(v)
        getgenv().PlayerMaterial = v
    end
})

Tab1:AddDropdown("PlayerAnimationDropdown", {
    Values = {"Static", "Wave", "Pulse", "Noise", "Lightning", "Scanline", "Grid"},
    Default = getgenv().PlayerAnim,
    Callback = function(v)
        getgenv().PlayerAnim = v
    end
})

getgenv().RunService.RenderStepped:Connect(function()
    if getgenv().PlayerChamsEnabled then ApplyPlayer() end
    if getgenv().GunChamsEnabled then ApplyGun() end
end)




local Players = cloneref(game:GetService("Players"))
local RunService = cloneref(game:GetService("RunService"))
local UserInputService = cloneref(game:GetService("UserInputService"))
local ProximityPromptService = cloneref(game:GetService("ProximityPromptService"))
local ReplicatedStorage = cloneref(game:GetService("ReplicatedStorage"))
local Lighting = cloneref(game:GetService("Lighting"))
local Workspace = cloneref(game:GetService("Workspace"))
local LocalPlayer = Players.LocalPlayer

local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

local ModFlags = {
    InfiniteHunger      = false,
    InfiniteStamina     = false,
    InfiniteSleep       = false,
    DisableCameraBobbing = false,
    DisableBloodEffects = false,
    NoFallDamage        = false,
    NoJumpCooldown      = false,
    DisableCameras      = false,
    NoKnockback         = false,
    RespawnWhereYouDied = false,
    InfiniteJump        = false,
    Fullbright          = false,
    Noclip              = false,
    QuickRespawn        = false,
    BypassLockedCars    = false,
}

local DeathFrame = nil
local OriginalSettings = {}
local SeatConnection = nil

local function enableFullbright()
    if not next(OriginalSettings) then
        OriginalSettings.Brightness     = Lighting.Brightness
        OriginalSettings.ClockTime      = Lighting.ClockTime
        OriginalSettings.FogEnd         = Lighting.FogEnd
        OriginalSettings.GlobalShadows  = Lighting.GlobalShadows
        OriginalSettings.OutdoorAmbient = Lighting.OutdoorAmbient
    end
    Lighting.Brightness     = 2
    Lighting.ClockTime      = 12
    Lighting.FogEnd         = 1e5
    Lighting.GlobalShadows  = false
    Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
end

local function disableFullbright()
    for prop, val in pairs(OriginalSettings) do
        Lighting[prop] = val
    end
end

local function findVehicleSeat(obj)
    while obj and obj.Parent do
        if obj:FindFirstChild("DriveSeat") then
            return obj.DriveSeat
        end
        obj = obj.Parent
    end
    return nil
end

local function SetupCharacterEvents(char)
    local hum = char:WaitForChild("Humanoid")
    local root = char:WaitForChild("HumanoidRootPart")

    hum.Died:Connect(function()
        DeathFrame = root.CFrame
    end)

    char.DescendantAdded:Connect(function(desc)
        if ModFlags.NoKnockback and (desc:IsA("BodyVelocity") or desc:IsA("LinearVelocity") or desc:IsA("VectorForce")) then
            task.wait()
            desc:Destroy()
        end
    end)

    task.delay(0.1, function()
        if ModFlags.RespawnWhereYouDied and typeof(DeathFrame) == "CFrame" and root and root.Parent then
            root.CFrame = DeathFrame
        end
    end)
end

if Character then SetupCharacterEvents(Character) end
LocalPlayer.CharacterAdded:Connect(SetupCharacterEvents)

RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local gui = LocalPlayer:FindFirstChild("PlayerGui")

    if gui then
        pcall(function()
            local hungerGui = gui:FindFirstChild("Hunger", true)
            if hungerGui then
                local script = hungerGui:FindFirstChild("HungerBarScript", true)
                if script then
                    script.Disabled = ModFlags.InfiniteHunger
                end
            end
        end)

        pcall(function()
            local runGui = gui:FindFirstChild("Run", true)
            if runGui then
                local script = runGui:FindFirstChild("StaminaBarScript", true)
                if script then
                    script.Disabled = ModFlags.InfiniteStamina
                end
            end
        end)

        pcall(function()
            local sleepGui = gui:FindFirstChild("SleepGui", true)
            if sleepGui then
                local script = sleepGui:FindFirstChild("sleepScript", true)
                if script then
                    script.Disabled = ModFlags.InfiniteSleep
                end
            end
        end)

        pcall(function()
            local bloodGui = gui:FindFirstChild("BloodGui")
            if bloodGui then
                bloodGui.Enabled = not ModFlags.DisableBloodEffects
            end
        end)

        pcall(function()
            local camTexts = gui:FindFirstChild("CameraTexts")
            if camTexts then
                camTexts.Enabled = not ModFlags.DisableCameras
                local ls = camTexts:FindFirstChild("LocalScript")
                if ls then
                    ls.Disabled = ModFlags.DisableCameras
                end
            end
        end)

        pcall(function()
            local jumpDebounce = gui:FindFirstChild("JumpDebounce")
            if jumpDebounce then
                local ls = jumpDebounce:FindFirstChild("LocalScript")
                if ls then
                    ls.Disabled = ModFlags.NoJumpCooldown
                end
            end
        end)
    end

    if char then
        pcall(function()
            local camBob = char:FindFirstChild("CameraBobbing")
            if camBob then camBob.Disabled = ModFlags.DisableCameraBobbing end
        end)

        pcall(function()
            local fallDamage = char:FindFirstChild("FallDamageRagdoll")
            if fallDamage then fallDamage.Disabled = ModFlags.NoFallDamage end
        end)
    end

    if ModFlags.Fullbright then
        enableFullbright()
    else
        disableFullbright()
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not ModFlags.InfiniteJump then return end
    if input.KeyCode == Enum.KeyCode.Space then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if not ModFlags.QuickRespawn then continue end
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum and hum.Health <= 0 then
            local respawnRE = ReplicatedStorage:FindFirstChild("RespawnRE", true)
            if respawnRE then
                respawnRE:FireServer()
            end
            task.wait(0.1)
        end
    end
end)


