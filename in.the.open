getgenv().ReplicatedStorage = cloneref(game:GetService("ReplicatedStorage"))
getgenv().Players = cloneref(game:GetService("Players"))
getgenv().Player = Players.LocalPlayer
getgenv().Character = nil
getgenv().Backpack = nil

getgenv().BLACKLIST = {
    ["Fist"] = true,
    ["Phone"] = true,
}

getgenv().Enabled = false
getgenv().Processing = false
getgenv().CachedTools = {}
getgenv().ListedIds = {}

getgenv().UpdateCharacter = function()
    Character = Player.Character or Player.CharacterAdded:Wait()
    Backpack = Player:WaitForChild("Backpack")
end

UpdateCharacter()
Player.CharacterAdded:Connect(UpdateCharacter)

getgenv().CacheInventory = function()
    if not Enabled or Processing then return end
    local tools = {}
    for _, v in ipairs(Backpack:GetChildren()) do
        if v:IsA("Tool") and not BLACKLIST[v.Name] then
            tools[v.Name] = true
        end
    end
    if Character then
        for _, v in ipairs(Character:GetChildren()) do
            if v:IsA("Tool") and not BLACKLIST[v.Name] then
                tools[v.Name] = true
            end
        end
    end
    CachedTools = {}
    for name in pairs(tools) do
        table.insert(CachedTools, name)
    end
    table.sort(CachedTools)
end

task.spawn(function()
    while true do
        CacheInventory()
        task.wait(1)
    end
end)

getgenv().CaptureListedIds = function()
    ListedIds = {}
    for _, item in ipairs(ReplicatedStorage.MarketItems:GetChildren()) do
        local owner = item:FindFirstChild("owner")
        if owner and owner.Value == Player.Name and not BLACKLIST[item.Name] then
            local id = item:GetAttribute("SpecialId")
            if id then
                ListedIds[id] = item.Name
            end
        end
    end
end

getgenv().IsListed = function(toolName)
    for _, item in ipairs(ReplicatedStorage.MarketItems:GetChildren()) do
        local owner = item:FindFirstChild("owner")
        if owner and owner.Value == Player.Name and item.Name == toolName then
            return true
        end
    end
    return false
end

getgenv().ListUntilDone = function()
    local listed = {}
    while true do
        local allDone = true
        for _, name in ipairs(CachedTools) do
            if not listed[name] and not IsListed(name) then
                ReplicatedStorage.ListWeaponRemote:FireServer(name, 990000)
                task.wait(1.8)
                if IsListed(name) then
                    listed[name] = true
                else
                    allDone = false
                end
            end
        end
        if allDone then break end
        task.wait(0.5)
    end
    task.wait(2)
    CaptureListedIds()
end

getgenv().OnCharacter = function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        if not Enabled or Processing then return end
        Processing = true
        

        ListUntilDone()
        

        Player.CharacterAdded:Wait()
        

        task.wait(8)
        

        local maxAttempts = 15
        local attempt = 0
        
        while attempt < maxAttempts do
            attempt = attempt + 1
            
            CaptureListedIds()
            
            if next(ListedIds) == nil then
    
                break
            end
            
         
            for id, name in pairs(ListedIds) do
                ReplicatedStorage.BuyItemRemote:FireServer(name, "Remove", id)
                task.wait(2)  
            end
            

            task.wait(3)  
        end
        
        Processing = false
    end)
end

OnCharacter(Character)
Player.CharacterAdded:Connect(OnCharacter)

