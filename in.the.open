getgenv().RunService = game:GetService("RunService")
getgenv().Players = game:GetService("Players")
getgenv().LocalPlayer = getgenv().Players.LocalPlayer

getgenv().StudioFarmConnections = getgenv().StudioFarmConnections or {}
getgenv().FreeFallLoop = nil
getgenv().SwimMethod = false

getgenv().UpdateCharacterReferences = function()
    getgenv().Character = getgenv().LocalPlayer.Character or getgenv().LocalPlayer.CharacterAdded:Wait()
    getgenv().Humanoid = getgenv().Character:WaitForChild("Humanoid")
    getgenv().HumanoidRootPart = getgenv().Character:WaitForChild("HumanoidRootPart")
end

getgenv().UpdateCharacterReferences()

if not getgenv().StudioFarmConnections["CharacterAdded"] then
    getgenv().StudioFarmConnections["CharacterAdded"] =
        getgenv().LocalPlayer.CharacterAdded:Connect(function()
            getgenv().UpdateCharacterReferences()
        end)
end

getgenv().UpdateFreeFall = function(state)
    if state then
        getgenv().SwimMethod = true

        if not getgenv().FreeFallLoop then
            getgenv().FreeFallLoop = getgenv().RunService.Heartbeat:Connect(function()
                if getgenv().Humanoid then
                    getgenv().Humanoid:ChangeState(Enum.HumanoidStateType.FallingDown)
                end
            end)
        end
    else
        getgenv().SwimMethod = false

        if getgenv().FreeFallLoop then
            getgenv().FreeFallLoop:Disconnect()
            getgenv().FreeFallLoop = nil
        end

        if getgenv().Humanoid then
            getgenv().Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
end

getgenv().TeleportTo = function(cf)
    if getgenv().LocalPlayer.Character and getgenv().LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        getgenv().LocalPlayer.Character.HumanoidRootPart.CFrame = cf
    end
end

getgenv().RobStudio = function(studioPay)
    getgenv().Character = getgenv().LocalPlayer.Character or getgenv().LocalPlayer.CharacterAdded:Wait()
    getgenv().RootPart = getgenv().Character:FindFirstChild("HumanoidRootPart")
    if not getgenv().RootPart then return end

    getgenv().OldCFrameStudio = getgenv().RootPart.CFrame

    getgenv().StudioPath = workspace.StudioPay.Money:FindFirstChild(studioPay)
    getgenv().Prompt =
        getgenv().StudioPath
        and getgenv().StudioPath:FindFirstChild("StudioMoney1")
        and getgenv().StudioPath.StudioMoney1:FindFirstChild("Prompt")

    if getgenv().Prompt then
        getgenv().TeleportTo(getgenv().Prompt.Parent.CFrame + Vector3.new(0,2,0))
        task.wait(0.1)

        getgenv().Prompt.HoldDuration = 0
        getgenv().Prompt.RequiresLineOfSight = false

        pcall(function()
            fireproximityprompt(getgenv().Prompt, 0)
        end)
    end

    task.wait(0.5)
    getgenv().TeleportTo(getgenv().OldCFrameStudio)
end

