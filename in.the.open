    end
end)


DupeGunBox:AddToggle('FireRateBoostToggle', {
    Text = 'Fire Rate Boost',
    Default = false,
    Callback = function(v)
        FireRateBoost = v
        if anyModEnabled() then
            startModLoop()
        else
            if modConnection then
                modConnection:Disconnect()
                modConnection = nil
            end
        end
    end,
})







local function anyModEnabled()
    return AlwaysAutomatic or NoRecoil or NoSpread or FireRateBoost or InfDamageEnabled or FastReload
end


local RunService = game:GetService("RunService")
local modConnection

local function startModLoop()
    if modConnection then return end
    
    modConnection = RunService.Heartbeat:Connect(function()
        if not anyModEnabled() then
            if modConnection then
                modConnection:Disconnect()
                modConnection = nil
            end
            applyInfDamage(InfDamageEnabled)
            return
        end
        
        for _, weapon in ipairs(WeaponTables) do
            pcall(function()
                rawset(weapon, "FireAnimationSpeed", 100)
                rawset(weapon, "FlamingBullet", true)
                rawset(weapon, "Auto", AlwaysAutomatic)
                rawset(weapon, "FireMode", AlwaysAutomatic and "Auto" or (rawget(weapon, "FireMode") or "Semi"))
                rawset(weapon, "BurstAmount", AlwaysAutomatic and 1 or (rawget(weapon, "BurstAmount") or 1))
                rawset(weapon, "ShotsPerBurst", AlwaysAutomatic and 1 or (rawget(weapon, "ShotsPerBurst") or 1))
                
                rawset(weapon, "CameraRecoilingEnabled", not NoRecoil)
                rawset(weapon, "Recoil", NoRecoil and 0 or (rawget(weapon, "Recoil") or 1))
                rawset(weapon, "Accuracy", NoSpread and 0 or (rawget(weapon, "Accuracy") or 1))
                rawset(weapon, "FireRate", FireRateBoost and 0.01 or (rawget(weapon, "FireRate") or 0.1))
                

                rawset(weapon, "ReloadTime", FastReload and 0.2 or (rawget(weapon, "ReloadTime") or 1))
            end)
        end
        
        applyInfDamage(InfDamageEnabled)
    end)
end




