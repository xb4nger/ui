    FadeIn(0.3)

    getgenv().UpdateFreeFall(true)
    task.wait(2)

    for _, pay in ipairs({"StudioPay1","StudioPay2","StudioPay3"}) do
        getgenv().RobStudio(pay)
    end

    task.wait(1)
    getgenv().UpdateFreeFall(false)

    getgenv().Character = getgenv().LocalPlayer.Character or getgenv().LocalPlayer.CharacterAdded:Wait()
    getgenv().RootPart = getgenv().Character:FindFirstChild("HumanoidRootPart")

    if getgenv().RootPart then
        getgenv().TeleportTo(getgenv().RootPart.CFrame)
    end

    FadeOut(0.4)
end)





