Cars1:AddButton("Explode All Cars [ Hold Gun ]", function()
    local LocalPlayer = game.Players.LocalPlayer
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local gun = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")



    local civCars = workspace:FindFirstChild("CivCars")
    if not civCars then return end


    local count = 0
    for _, car in ipairs(civCars:GetChildren()) do
        if car:IsA("Model") then
            count += 1
            task.spawn(function()
                local success, part = pcall(function()
                    return car:FindFirstChildWhichIsA("BasePart") or car.PrimaryPart
                end)
                if not success or not part then return end

                for i = 1, 4000 do
                    pcall(function()
                        ReplicatedStorage.InflictCar:InvokeServer(
                            gun,
                            car,
                            part,
                            9e50
                        )
                    end)
                end
            end)
        end
    end


end)


local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local CivCars = workspace:WaitForChild("CivCars")


local lastCarIndex = 0

local function findVehicleSeat(obj)
    while obj and obj.Parent do
        if obj:FindFirstChild("DriveSeat") then
            return obj.DriveSeat
        end
        obj = obj.Parent
    end
end

local function getNextEmptyCar()
    local cars = CivCars:GetChildren()
    local numCars = #cars
    if numCars == 0 then return nil end

    for i = 1, numCars do
        -- Loop in rotation
        local index = ((lastCarIndex + i - 1) % numCars) + 1
        local car = cars[index]
        local seat = findVehicleSeat(car)
        if seat and not seat.Occupant then
            lastCarIndex = index 
            return seat
        end
    end
    return nil 
end

local function teleportToSeat(seat)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:WaitForChild("HumanoidRootPart")
    root.CFrame = seat.CFrame + Vector3.new(0, 5, 0) 
end

local function sitInSeat(seat)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")

    if seat:IsA("VehicleSeat") then
        seat:Sit(humanoid)
    else
        humanoid.Sit = false
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait()
        seat:Sit(humanoid)
    end
end

Cars1:AddButton("Steal Random Car", function()
    local seat = getNextEmptyCar()
    if not seat then
        warn("No empty cars available!")
        return
    end

    teleportToSeat(seat)
    task.wait(0.1)
    sitInSeat(seat)
end)








