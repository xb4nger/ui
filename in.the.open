local ReplicatedStorage = cloneref(game:GetService("ReplicatedStorage"))
local Players = cloneref(game:GetService("Players"))

local Player = Players.LocalPlayer
local Character, Backpack

local function updateCharacter()
    Character = Player.Character or Player.CharacterAdded:Wait()
    Backpack = Player:WaitForChild("Backpack")
end

updateCharacter()

Player.CharacterAdded:Connect(function()
    updateCharacter()
end)

local running = false

local BLACKLIST = {
    ["Fist"] = true,
    ["Phone"] = true,
}

local function getValidTool()

    for _, tool in ipairs(Character:GetChildren()) do
        if tool:IsA("Tool") and not BLACKLIST[tool.Name] then
            return tool
        end
    end

    for _, tool in ipairs(Backpack:GetChildren()) do
        if tool:IsA("Tool") and not BLACKLIST[tool.Name] then
            return tool
        end
    end
    return nil
end

local function getPing()
    if typeof(Player.GetNetworkPing) == "function" then
        local s, r = pcall(function()
            return tonumber(string.match(Player:GetNetworkPing(), "%d+"))
        end)
        if s and r then return r end
    end
    local t0 = tick()
    local v = Instance.new("BoolValue")
    v.Parent = ReplicatedStorage
    v.Name = "PingTest_" .. tostring(math.random(10000, 99999))
    task.wait(0.1)
    local t1 = tick()
    v:Destroy()
    return math.clamp((t1 - t0) * 1000, 50, 300)
end

local function dupeOne()
    local Tool = getValidTool()
    if not Tool then return end

    Tool.Parent = Backpack
    task.wait(0.5)

    local ToolName = Tool.Name
    local ToolId
    local delay = 0.25 + ((math.clamp(getPing(), 0, 300) / 300) * 0.03)

    local conn; conn = ReplicatedStorage.MarketItems.ChildAdded:Connect(function(item)
        if item.Name == ToolName then
            local owner = item:WaitForChild("owner", 2)
            if owner and owner.Value == Player.Name then
                ToolId = item:GetAttribute("SpecialId")
            end
        end
    end)

    task.spawn(function()
        ReplicatedStorage.ListWeaponRemote:FireServer(ToolName, 99999)
    end)

    task.wait(delay)

    task.spawn(function()
        ReplicatedStorage.BackpackRemote:InvokeServer("Store", ToolName)
    end)

    task.wait(3)

    if ToolId then
        task.spawn(function()
            ReplicatedStorage.BuyItemRemote:FireServer(ToolName, "Remove", ToolId)
        end)
    end

    task.spawn(function()
        ReplicatedStorage.BackpackRemote:InvokeServer("Grab", ToolName)
    end)

    conn:Disconnect()
end

task.spawn(function()
    while true do
        if running then
            dupeOne()
            task.wait(1.5)
        else
            task.wait(0.1)
        end
    end
end)

DupeGunBox:AddButton('Dupe Gun', function()
    dupeOne()
end)

DupeGunBox:AddToggle('AutoDupeGunToggle', {
    Text = 'Auto Dupe Gun',
    Default = false,
    Callback = function(v)
        running = v
    end,
})

local AlwaysAutomatic = false
local NoRecoil = false
local NoSpread = false
local FireRateBoost = false

local WeaponTables = {}
local originalDamages = {}

local function cacheWeaponTables()
    WeaponTables = {}
    for _, obj in ipairs(getgc(true)) do
        if typeof(obj) == "table" and rawget(obj, "FireRate") then
            table.insert(WeaponTables, obj)
        end
    end
end

local function setupAutoRefresh()
    local player = game:GetService("Players").LocalPlayer
    
    player.CharacterAdded:Connect(function()
        task.wait(1)
        cacheWeaponTables()
    end)
    
    if player.Character then
        player.Character.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.spawn(cacheWeaponTables)
            end
        end)
    end
end

cacheWeaponTables()
setupAutoRefresh()

local function getEquippedTool()
    local char = game:GetService("Players").LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Tool")
end

local function applyInfDamage(state)
    local tool = getEquippedTool()
    if not tool then return end
    
    local setting = tool:FindFirstChild("Setting")
    if not setting then return end
    
    local toolKey = tool:GetDebugId()
    
    if state then
        if not originalDamages[toolKey] then
            originalDamages[toolKey] = setting.BaseDamage.Value or setting.BaseDamage
        end
        setting.BaseDamage = 9e9
    else
        if originalDamages[toolKey] then
            setting.BaseDamage = originalDamages[toolKey]
            originalDamages[toolKey] = nil
        end
    end
end

local RunService = game:GetService("RunService")
local modConnection

local function anyModEnabled()
    return AlwaysAutomatic or NoRecoil or NoSpread or FireRateBoost or InfDamageEnabled
end

local function startModLoop()
    if modConnection then return end
    
    modConnection = RunService.Heartbeat:Connect(function()
        if not anyModEnabled() then
            if modConnection then
                modConnection:Disconnect()
                modConnection = nil
            end
            applyInfDamage(false)
            return
        end
        
        for _, weapon in ipairs(WeaponTables) do
            pcall(function()
                rawset(weapon, "FireAnimationSpeed", 100)
                rawset(weapon, "FlamingBullet", true)
                rawset(weapon, "Auto", AlwaysAutomatic)
                rawset(weapon, "FireMode", AlwaysAutomatic and "Auto" or (rawget(weapon, "FireMode") or "Semi"))
                rawset(weapon, "BurstAmount", AlwaysAutomatic and 1 or (rawget(weapon, "BurstAmount") or 1))
                rawset(weapon, "ShotsPerBurst", AlwaysAutomatic and 1 or (rawget(weapon, "ShotsPerBurst") or 1))
                
                rawset(weapon, "CameraRecoilingEnabled", not NoRecoil)
                rawset(weapon, "Recoil", NoRecoil and 0 or (rawget(weapon, "Recoil") or 1))
                rawset(weapon, "Accuracy", NoSpread and 0 or (rawget(weapon, "Accuracy") or 1))
                rawset(weapon, "FireRate", FireRateBoost and 0.01 or (rawget(weapon, "FireRate") or 0.1))
            end)
        end
        
        applyInfDamage(InfDamageEnabled)
    end)
end

