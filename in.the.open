local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

getgenv().LocalPlayer = Players.LocalPlayer
getgenv().Camera = Workspace.CurrentCamera

getgenv().Character = getgenv().LocalPlayer.Character or getgenv().LocalPlayer.CharacterAdded:Wait()
getgenv().LocalPlayer.CharacterAdded:Connect(function(newChar)
    getgenv().Character = newChar
end)

getgenv().flySpeed = 50
getgenv().FLYING = false
getgenv().SwimMethod = false
getgenv().CFloop = nil
getgenv().RemovedHair = {}

RunService.Stepped:Connect(function()
    if getgenv().SwimMethod and getgenv().Character then
        local hum = getgenv().Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.FallingDown) end
    end
end)

WalkGroupbox:AddToggle('FlyToggle', {
    Text = 'Fly',
    Default = false,
    Callback = function(state)
        getgenv().FLYING = state
        local camera = workspace.CurrentCamera
        if state then
            getgenv().SwimMethod = true
            task.wait(0.3)
            local char = getgenv().LocalPlayer.Character or getgenv().LocalPlayer.CharacterAdded:Wait()
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then return end
            hum.PlatformStand = true
            local Head = char:WaitForChild("Head")
            Head.Anchored = true
            getgenv().RemovedHair = {}
            for _, acc in ipairs(char:GetChildren()) do
                if acc:IsA("Accessory") then
                    local h = acc:FindFirstChild("Handle")
                    if h then
                        local m = h:FindFirstChildOfClass("SpecialMesh")
                        if m and (m.MeshId:lower():find("hair") or acc.Name:lower():find("hair")) then
                            getgenv().RemovedHair[acc] = true
                            acc.Parent = nil
                        end
                    elseif acc.Name:lower():find("hair") then
                        getgenv().RemovedHair[acc] = true
                        acc.Parent = nil
                    end
                end
            end
            camera.CameraSubject = Head
            camera.CameraType = Enum.CameraType.Custom
            getgenv().LocalPlayer.CameraMinZoomDistance = 0.5
            getgenv().LocalPlayer.CameraMaxZoomDistance = 0.5
            if getgenv().CFloop then getgenv().CFloop:Disconnect() end
            getgenv().CFloop = RunService.Heartbeat:Connect(function(dt)
                local move = hum.MoveDirection * (getgenv().flySpeed * dt)
                local hcf = Head.CFrame
                local ccf = camera.CFrame
                local off = hcf:ToObjectSpace(ccf).Position
                ccf = ccf * CFrame.new(-off.X, -off.Y, -off.Z + 1)
                local cp = ccf.Position
                local hp = hcf.Position
                local vel = CFrame.new(cp, Vector3.new(hp.X, cp.Y, hp.Z)):VectorToObjectSpace(move)
                Head.CFrame = CFrame.new(hp) * (ccf - cp) * CFrame.new(vel)
                camera.CameraSubject = Head
                getgenv().LocalPlayer.CameraMinZoomDistance = 0.1
                getgenv().LocalPlayer.CameraMaxZoomDistance = 0.1
            end)
        else
            if getgenv().CFloop then getgenv().CFloop:Disconnect() getgenv().CFloop = nil end
            local char = getgenv().LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then hum.PlatformStand = false end
            local Head = char and char:FindFirstChild("Head")
            if Head then Head.Anchored = false end
            getgenv().SwimMethod = false
            if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
            getgenv().LocalPlayer.CameraMinZoomDistance = 0.5
            getgenv().LocalPlayer.CameraMaxZoomDistance = 400
            for acc in pairs(getgenv().RemovedHair) do
                if char and not acc.Parent then acc.Parent = char end
            end
            getgenv().RemovedHair = {}
        end
    end,
}):AddKeyPicker('FlyBind', {
    Default = '',
    SyncToggleState = true,
    Mode = 'Toggle',
    Text = 'Fly',
    NoUI = false,
    Toggle = 'FlyToggle'
})

WalkGroupbox:AddSlider('FlySpeedSlider', {
    Text = 'Speed',
    Min = 1,
    Max = 200,
    Default = 50,
    Rounding = 1,
    Callback = function(v)
        getgenv().flySpeed = v
    end,
})

getgenv().CarFlyEnabled = false
getgenv().CarFlySpeed = 100
getgenv().FLYING = false
getgenv().CONTROL = {F=0,B=0,L=0,R=0,Q=0,E=0}
getgenv().OriginalCollisions = {}
getgenv().Platform = nil
getgenv().PlatformWeld = nil
getgenv().FlyBV = nil
getgenv().FlyBG = nil
getgenv().VehicleModel = nil
getgenv().VehiclePart = nil
getgenv().CarFlyConnection = nil

local function getVehicle()
    local hum = getgenv().Character and getgenv().Character:FindFirstChildOfClass("Humanoid")
    if hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
        local m = hum.SeatPart:FindFirstAncestorOfClass("Model")
        return m, m and (m.PrimaryPart or hum.SeatPart)
    end
end

local function setCollisions(model, enable)
    if not model then return end
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") then
            if enable then
                if getgenv().OriginalCollisions[p] ~= nil then
                    p.CanCollide = getgenv().OriginalCollisions[p]
                    getgenv().OriginalCollisions[p] = nil
                end
            else
                if getgenv().OriginalCollisions[p] == nil then
                    getgenv().OriginalCollisions[p] = p.CanCollide
                    p.CanCollide = false
                end
            end
        end
    end
end

local function startCarFly()
    if getgenv().FLYING then return end
    getgenv().VehicleModel, getgenv().VehiclePart = getVehicle()
    if not getgenv().VehiclePart then return end
    getgenv().FLYING = true
    setCollisions(getgenv().VehicleModel, false)
    getgenv().Platform = Instance.new("Part")
    getgenv().Platform.Size = Vector3.new(8, 1, 12)
    getgenv().Platform.CFrame = getgenv().VehiclePart.CFrame * CFrame.new(0, -getgenv().VehiclePart.Size.Y/2 - 1, 0)
    getgenv().Platform.CanCollide = false
    getgenv().Platform.Transparency = 1
    getgenv().Platform.Massless = true
    getgenv().Platform.Parent = Workspace
    getgenv().PlatformWeld = Instance.new("WeldConstraint")
    getgenv().PlatformWeld.Part0 = getgenv().Platform
    getgenv().PlatformWeld.Part1 = getgenv().VehicleModel.PrimaryPart or getgenv().VehiclePart
    getgenv().PlatformWeld.Parent = getgenv().Platform
    getgenv().FlyBV = Instance.new("BodyVelocity", getgenv().Platform)
    getgenv().FlyBV.MaxForce = Vector3.new(9e9,9e9,9e9)
    getgenv().FlyBV.P = 12500
    getgenv().FlyBG = Instance.new("BodyGyro", getgenv().Platform)
    getgenv().FlyBG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    getgenv().FlyBG.P = 90000
    getgenv().FlyBG.D = 3000
    getgenv().FlyBG.CFrame = getgenv().Platform.CFrame
    getgenv().CarFlyConnection = RunService.RenderStepped:Connect(function()
        if not getgenv().FLYING or not getgenv().Platform or not getgenv().VehiclePart then return end
        local mv = Vector3.zero
        if getgenv().CONTROL.F ~= 0 then mv += getgenv().Camera.CFrame.LookVector * getgenv().CONTROL.F end
        if getgenv().CONTROL.B ~= 0 then mv -= getgenv().Camera.CFrame.LookVector * getgenv().CONTROL.B end
        if getgenv().CONTROL.L ~= 0 then mv -= getgenv().Camera.CFrame.RightVector * getgenv().CONTROL.L end
        if getgenv().CONTROL.R ~= 0 then mv += getgenv().Camera.CFrame.RightVector * getgenv().CONTROL.R end
        if getgenv().CONTROL.E ~= 0 then mv += getgenv().Camera.CFrame.UpVector * getgenv().CONTROL.E end
        if getgenv().CONTROL.Q ~= 0 then mv -= getgenv().Camera.CFrame.UpVector * getgenv().CONTROL.Q end
        getgenv().FlyBV.Velocity = mv.Magnitude > 0 and mv.Unit * getgenv().CarFlySpeed or Vector3.zero
        getgenv().FlyBG.CFrame = CFrame.new(getgenv().Platform.Position, getgenv().Platform.Position + getgenv().Camera.CFrame.LookVector)
    end)
end

local function stopCarFly()
    getgenv().FLYING = false
    if getgenv().CarFlyConnection then getgenv().CarFlyConnection:Disconnect() end
    if getgenv().FlyBV then getgenv().FlyBV:Destroy() end
    if getgenv().FlyBG then getgenv().FlyBG:Destroy() end
    if getgenv().PlatformWeld then getgenv().PlatformWeld:Destroy() end
    if getgenv().Platform then getgenv().Platform:Destroy() end
    if getgenv().VehicleModel then setCollisions(getgenv().VehicleModel, true) end
end

UserInputService.InputBegan:Connect(function(i,g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.W then getgenv().CONTROL.F = 1
    elseif i.KeyCode == Enum.KeyCode.S then getgenv().CONTROL.B = 1
    elseif i.KeyCode == Enum.KeyCode.A then getgenv().CONTROL.L = 1
    elseif i.KeyCode == Enum.KeyCode.D then getgenv().CONTROL.R = 1
    elseif i.KeyCode == Enum.KeyCode.E then getgenv().CONTROL.E = 1
    elseif i.KeyCode == Enum.KeyCode.Q then getgenv().CONTROL.Q = 1
    elseif i.KeyCode == Enum.KeyCode.F then
        getgenv().CarFlyEnabled = not getgenv().CarFlyEnabled
        if getgenv().CarFlyEnabled then startCarFly() else stopCarFly() end
    end
end)

UserInputService.InputEnded:Connect(function(i,g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.W then getgenv().CONTROL.F = 0
    elseif i.KeyCode == Enum.KeyCode.S then getgenv().CONTROL.B = 0
    elseif i.KeyCode == Enum.KeyCode.A then getgenv().CONTROL.L = 0
    elseif i.KeyCode == Enum.KeyCode.D then getgenv().CONTROL.R = 0
    elseif i.KeyCode == Enum.KeyCode.E then getgenv().CONTROL.E = 0
    elseif i.KeyCode == Enum.KeyCode.Q then getgenv().CONTROL.Q = 0 end
end)

getgenv().moveConnection = nil
getgenv().movementEnabled = false
getgenv().currentWalkSpeed = 16
getgenv().fastFallSpeed = -200

local function getHumanoid()
    local c = getgenv().LocalPlayer.Character
    if c then return c:FindFirstChildOfClass("Humanoid") end
end

local function keepUpright()
    local c = getgenv().LocalPlayer.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.RotVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(hrp.CFrame.LookVector.X, 0, hrp.CFrame.LookVector.Z))
end

local function isGrounded(hrp)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {getgenv().LocalPlayer.Character}
    rp.FilterType = Enum.RaycastFilterType.Blacklist
    return Workspace:Raycast(hrp.Position, Vector3.new(0,-6,0), rp) ~= nil
end

local function teleportForward(dist)
    local c = getgenv().LocalPlayer.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local h = c:FindFirstChildOfClass("Humanoid")
    if not hrp or not h then return end
    h:ChangeState(0)
    repeat task.wait() until not getgenv().LocalPlayer:GetAttribute("LastACPos")
    local origin = hrp.Position
    local dir = hrp.CFrame.LookVector * dist
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {c}
    rp.FilterType = Enum.RaycastFilterType.Blacklist
    local rc = Workspace:Raycast(origin, dir, rp)
    local pos = rc and (rc.Position - hrp.CFrame.LookVector * 2) or (origin + dir)
    if not isGrounded(hrp) then
        hrp.Velocity = Vector3.new(hrp.Velocity.X, getgenv().fastFallSpeed, hrp.Velocity.Z)
    else
        hrp.Velocity = Vector3.zero
    end
    hrp.CFrame = CFrame.new(pos, pos + hrp.CFrame.LookVector)
    keepUpright()
end

local function startWalkLoop()
    if getgenv().moveConnection then getgenv().moveConnection:Disconnect() end
    getgenv().moveConnection = RunService.Heartbeat:Connect(function(dt)
        if getgenv().movementEnabled then
            local h = getHumanoid()
            if h then
                keepUpright()
                if h.MoveDirection.Magnitude > 0 then
                    teleportForward(getgenv().currentWalkSpeed * dt)
                else
                    local hrp = getgenv().LocalPlayer.Character and getgenv().LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and not isGrounded(hrp) then
                        hrp.Velocity = Vector3.new(hrp.Velocity.X, getgenv().fastFallSpeed, hrp.Velocity.Z)
                    end
                end
            end
        end
    end)
end

local function stopWalkLoop()
    if getgenv().moveConnection then getgenv().moveConnection:Disconnect() end
    keepUpright()
end

