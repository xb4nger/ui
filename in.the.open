local MenuGroup = Tabs.Settings:AddLeftGroupbox('Menu')

local Server = Tabs.Settings:AddRightGroupbox('Server')




getgenv().TargetPlaceId          = 16472538603
getgenv().ServerHopEnabled       = true
getgenv().LowPlayerThreshold     = 1
getgenv().Http                   = game:GetService("HttpService")
getgenv().TS                     = game:GetService("TeleportService")
getgenv().PlayersService         = game:GetService("Players")
getgenv().LocalPlr               = getgenv().PlayersService.LocalPlayer

Server:AddButton('Join Low Server', function()
    local PlaceId   = getgenv().TargetPlaceId
    local MyJobId   = game.JobId
    local Cursor    = ""
    
    local LowestServer = nil
    local LowestCount  = math.huge
    
    repeat
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        if Cursor ~= "" then
            url = url .. "&cursor=" .. Cursor
        end
        
        local success, raw = pcall(game.HttpGet, game, url)
        if not success then
            warn("HttpGet failed: " .. tostring(raw))
            break
        end
        
        local data = getgenv().Http:JSONDecode(raw)
        if not (data and data.data) then
            warn("Invalid servers response")
            break
        end
        
        for _, srv in data.data do
            if srv.id ~= MyJobId and srv.playing > 0 then
                if srv.playing < LowestCount then
                    LowestCount  = srv.playing
                    LowestServer = srv.id
                    
                    if LowestCount <= getgenv().LowPlayerThreshold then
                        break
                    end
                end
            end
        end
        
        if LowestCount <= getgenv().LowPlayerThreshold then
            break
        end
        
        Cursor = data.nextPageCursor
    until not Cursor
    
    if LowestServer then
        print("Joining → " .. LowestCount .. " players")
        getgenv().TS:TeleportToPlaceInstance(PlaceId, LowestServer, getgenv().LocalPlr)
    else
        warn("No low-player server found")
    end
end)


Server:AddButton('Server Hop', function()
    if not getgenv().ServerHopEnabled then return end
    
    local PlaceId = game.PlaceId
    local MyJobId = game.JobId
    
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, raw = pcall(game.HttpGet, game, url)
    if not success then
        warn("HttpGet failed: " .. tostring(raw))
        return
    end
    
    local data = getgenv().Http:JSONDecode(raw)
    if not (data and data.data) then
        warn("Invalid servers response")
        return
    end
    
    for _, srv in data.data do
        if srv.id ~= MyJobId and srv.playing < srv.maxPlayers then
            print("Hopping → " .. srv.playing .. "/" .. srv.maxPlayers)
            getgenv().TS:TeleportToPlaceInstance(PlaceId, srv.id, getgenv().LocalPlr)
            break
        end
    end
end)


Server:AddButton('Rejoin', function()
    print("Rejoining...")
    getgenv().TS:Teleport(game.PlaceId, getgenv().LocalPlr)
end)



MenuGroup:AddLabel("Menu bind"):AddKeyPicker("MenuKeybind", {
    Default = "RightShift",
    NoUI = true,
    Text = "Menu keybind"
})

task.spawn(function()
    local UserInputService = game:GetService("UserInputService")
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode.Name == Options.MenuKeybind.Value then
            Library:Toggle()
        end
    end)
end)




MenuGroup:AddDivider()
MenuGroup:AddButton("Unload", function() Library:Unload() end)



ThemeManager:SetLibrary(Library)
SaveManager:SetLibrary(Library)


SaveManager:SetIgnoreIndexes({ "MenuKeybind" })

ThemeManager:SetFolder("MyScriptHub")
SaveManager:SetFolder("MyScriptHub/specific-game")

SaveManager:BuildConfigSection(Tabs["Settings"])
ThemeManager:ApplyToTab(Tabs["Settings"])


Library:OnUnload(function()

end)









