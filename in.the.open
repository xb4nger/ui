getgenv().Players = game:GetService("Players")
getgenv().LocalPlayer = Players.LocalPlayer

getgenv().hitboxEnabled = false
getgenv().hitboxSize = 15
getgenv().hitboxPart = "Head"
getgenv().hitboxModel = "Default"
getgenv().Transparency = 0.5

getgenv().ORIGINAL = {}
getgenv().BOXES = {}

getgenv().getPart = function(character)
    if getgenv().hitboxPart == "Head" then
        return character:FindFirstChild("Head")
    else
        return character:FindFirstChild("UpperTorso")
            or character:FindFirstChild("Torso")
            or character:FindFirstChild("HumanoidRootPart")
    end
end

getgenv().saveOriginal = function(part)
    if not getgenv().ORIGINAL[part] then
        getgenv().ORIGINAL[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            CanCollide = part.CanCollide,
            Massless = part.Massless
        }
    end
end

getgenv().removeBox = function(part)
    local box = getgenv().BOXES[part]
    if box then
        box:Destroy()
        getgenv().BOXES[part] = nil
    end
end

getgenv().restorePart = function(part)
    getgenv().removeBox(part)
    local data = getgenv().ORIGINAL[part]
    if data and part then
        part.Size = data.Size
        part.Transparency = data.Transparency
        part.CanCollide = data.CanCollide
        part.Massless = data.Massless
        getgenv().ORIGINAL[part] = nil
    end
end

getgenv().restoreAll = function()
    for part in pairs(getgenv().ORIGINAL) do
        if part and part.Parent then
            getgenv().restorePart(part)
        end
    end
end

getgenv().createBoxHitbox = function(part, size)
    getgenv().removeBox(part)

    local box = Instance.new("Part")
    box.Size = Vector3.new(size, size, size)
    box.Transparency = getgenv().Transparency
    box.CanCollide = false
    box.CanTouch = false
    box.CanQuery = false
    box.Massless = true
    box.Anchored = false
    box.Color = Color3.new(1, 0, 0)
    box.Name = "HitboxBox"

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = part
    weld.Part1 = box
    weld.Parent = box

    box.CFrame = part.CFrame
    box.Parent = part.Parent

    getgenv().BOXES[part] = box

    part.Transparency = 1
    part.CanCollide = false
end

getgenv().ApplyHitbox = function(player)
    if player == getgenv().LocalPlayer then return end

    local function expand()
        if not getgenv().hitboxEnabled then return end
        local part = player.Character and getgenv().getPart(player.Character)
        if part and part:IsA("BasePart") then
            getgenv().saveOriginal(part)
            local size = getgenv().hitboxSize * 2

            if getgenv().hitboxModel == "Box" then
                getgenv().createBoxHitbox(part, size)
            else
                getgenv().removeBox(part)
                part.Transparency = getgenv().Transparency
                part.Size = Vector3.new(size, size, size)
                part.CanCollide = false
                part.CanTouch = false
                part.CanQuery = false
                part.Massless = true
            end
        end
    end

    player.CharacterAppearanceLoaded:Connect(function()
        task.wait(0.1)
        expand()
    end)

    if player.Character then
        expand()
    end
end

getgenv().UpdateHitboxes = function()
    getgenv().restoreAll()
    if not getgenv().hitboxEnabled then return end
    for _, player in ipairs(getgenv().Players:GetPlayers()) do
        getgenv().ApplyHitbox(player)
    end
end

