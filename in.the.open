local instantPromptConn
local function updateInstantInteraction(enabled)
    if enabled then
        -- Apply once to existing prompts
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                v.HoldDuration = 0
            end
        end

        -- Connect only once
        if not instantPromptConn then
            instantPromptConn = Workspace.DescendantAdded:Connect(function(v)
                if v:IsA("ProximityPrompt") then
                    v.HoldDuration = 0
                end
            end)
        end
    else


        if instantPromptConn then
            instantPromptConn:Disconnect()
            instantPromptConn = nil
        end
    end
end

